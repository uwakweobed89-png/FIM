# Login Detector Environment Variables
# Copy this to .env and fill in your actual credentials
# NEVER commit .env to version control!

# Email Configuration (for alerts)
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_RECIPIENT=security-team@yourcompany.com

# Elastic SIEM Configuration
ELASTIC_API_KEY=your-elastic-api-key-here

# Optional: Override config.yaml settings
# MODE=active
# MAX_ATTEMPTS=5
# LOCKOUT_MINUTES=15
